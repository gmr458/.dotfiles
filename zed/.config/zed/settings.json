{
  "assistant": {
    "enabled": false,
    "button": false,
    "version": "2"
  },
  "features": {
    "inline_completion_provider": "none",
    "copilot": false
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "vim_mode": true,
  "vim": {
    "toggle_relative_line_numbers": true
  },
  "ui_font_size": 15,
  "buffer_font_size": 16,
  "ui_font_family": "Roboto",
  "buffer_font_family": "Iosevka",
  "ui_font_weight": 400,
  "buffer_font_weight": 400,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Base16 Black Metal (Bathory) Dark"
  },
  "chat_panel": { "button": false },
  "collaboration_panel": { "button": false },
  "show_call_status_icon": false,
  "performance": { "show_in_status_bar": false },
  "terminal": {
    "font_weight": 400
  },
  "tab_bar": { "show": false },
  "git": {
    "inline_blame": { "enabled": false }
  }
}
