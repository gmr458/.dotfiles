(defwidget bar []
  (centerbox :orientation "h"
    (left)
    (center)
    (right)))

(defwidget right []
    (box :class "right" :orientation "h" :space-evenly false :halign "end"
        (box :class "clock" {"󰥔 " + time})
        (button
            :class "button-powermenu"
            :onclick "~/.config/tofi/scripts/powermenu.sh &"
            "󰤆"
        )
    )
)


(deflisten workspaces_listen "scripts/workspaces.sh")
(defwidget left []
    (box :class "left" :orientation "h" :space-evenly false :halign "start"
        (button
            :class "button-launcher"
            :onclick "~/.config/tofi/scripts/drun.sh &"
            "󱗼")
        (literal :content workspaces_listen)
    )
)

(defwidget center []
    (box
        :class "center"
        :orientation "h"
        :space-evenly false
        :halign "center"
        ""
    )
)


