;   (bar))


(defwindow bar
    :monitor 0
    :exclusive true
    :geometry (geometry
        :x "0%"
        :y "0%"
        :width  "98%"
        :height '10px'
        :anchor "top center"
    )

    :stacking "fg"
    :exclusive true
    :focusable false

    (bar)
)
