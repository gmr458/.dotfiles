# vim: ft=dosini

; SPECIAL OPTIONS
; include=

; BEHAVIOR OPTIONS
hide-cursor = true
text-cursor = true
history = true
; history-file = 
fuzzy-match = false
require-match = true
auto-accept-single = false
hide-input = false
hidden-character = \*
drun-launch = false
; terminal = alacritty
late-keyboard-init = false
multi-instance = false
ascii-input = true

# STYLE OPTIONS
font = ~/.local/share/fonts/iosevka-regular.ttf
font-size = 24
font-features = ""
font-variations = ""
background-color = #000A
outline-width = 0
outline-color = #080800
border-width = 0
border-color = #F92672
text-color = #ffffff
prompt-text = "Apps: "
prompt-padding = 0
prompt-color = #ffffff
prompt-background = #00000000
prompt-background-padding = 0
prompt-background-corner-radius = 0
placeholder-text = ""
placeholder-color = #FFFFFFA8
placeholder-background = #00000000
placeholder-background-padding = 0
placeholder-background-corner-radius = 0
input-color = #ffffff
input-background = #00000000
input-background-padding = 0
input-background-corner-radius = 0
text-cursor-style = bar
text-cursor-color = #ffffff
; text-cursor-background = 
text-cursor-corner-radius = 0
; text-cursor-thickness = 
; default-result-color = 
default-result-background = #00000000
default-result-background-padding = 0
default-result-background-corner-radius = 0
; alternate-result-color =
; alternate-result-background = 
; alternate-result-background-padding =
; alternate-result-background-corner-radius = 
num-results = 7
selection-color = #F92672
selection-match-color = #00000000
selection-padding = 0
selection-background = #00000000
selection-background-padding = 0
selection-background-corner-radius = 0
result-spacing = 5
; min-input-width = 
width = 100%
height = 100%
corner-radius = 0
anchor = center
exclusive-zone = -1
output = ""
scale = true
margin-top = 0
margin-bottom = 0
margin-left = 0
margin-right = 0
padding-top = 20%
padding-bottom = 20%
padding-left = 25%
padding-right = 8
clip-to-padding = true
horizontal = false
hint-font = false
