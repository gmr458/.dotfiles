include=./themes/black-and-white

; Behavior options
hide-cursor        = false
history            = true
fuzzy-match        = false
require-match      = true
hide-input         = false
hidden-character   = *
drun-launch        = false
; terminal         = alacritty
late-keyboard-init = false
multi-instance     = false

; Style options
font                  = Iosevka Fixed
font-size             = 20
outline-width         = 1%
border-width          = 0
prompt-text           = "Power Menu: "
prompt-padding        = 0
num-results           = 0
selection-padding     = 0
result-spacing        = 0
min-input-width       = 0
width                 = 28%
height                = 36%
corner-radius         = 14px
anchor                = center
exclusive-zone        = -1
output                = ""
scale                 = true
margin-top            = 0
margin-bottom         = 0
margin-left           = 0
margin-right          = 0
padding-top           = 2%
padding-bottom        = 1%
padding-left          = 2%
padding-right         = 2%
horizontal            = false
hint-font             = true
