set background=dark
set clipboard=unnamedplus
set cmdheight=1
set completeopt=menu,menuone,noselect
set confirm
set cursorline
set expandtab
set guifont=Iosevka\ Fixed:h14
set laststatus=2
set mouse=a
set number
set numberwidth=1
" set omnifunc=
set pumheight=0
" set relativenumber
set scroll=4
set sidescrolloff=4
set shiftwidth=4
set showmode
set showtabline=0
set sidescroll=5
set sidescrolloff=5
set signcolumn=no
" set smartcase
set smartindent
set nospell
" set spelllang
set splitbelow
set splitright
set noswapfile
" set tabline
set tabstop=4
"set termguicolors
"set t_Co=256
set nowrap

" colorscheme enfocado
"syntax on

inoremap jk <ESC>
